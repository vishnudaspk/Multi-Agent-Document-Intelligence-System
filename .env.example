# ─── Copy this to .env and fill in your values ───────────────────────────────

# PostgreSQL
POSTGRES_USER=madis_user          # [CONFIGURE THIS]
POSTGRES_PASSWORD=madis_pass      # [CONFIGURE THIS]
POSTGRES_DB=madis_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://madis_user:madis_pass@localhost:5432/madis_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=documents

# LLM — Ollama (default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:7b-instruct-q4_K_M

# LLM — LMStudio (alternative, comment out Ollama block above)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1   # [CONFIGURE THIS] match LMStudio port
# LMSTUDIO_API_KEY=lm-studio                   # LMStudio accepts any non-empty key

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
